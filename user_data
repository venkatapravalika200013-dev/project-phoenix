#!/bin/bash
# Project Phoenix - EC2 User Data Script
# Installs Docker, XFCE Desktop, TigerVNC, and required DevOps tools
# Execution: ~5-10 minutes on first boot

set -e

# Log output
exec > >(tee /var/log/phoenix-userdata.log)
exec 2>&1

echo "=== Project Phoenix EC2 Initialization Starting ==="
echo "Time: $(date)"

# ============================================
# 1. UPDATE SYSTEM
# ============================================
echo "[1/6] Updating system packages..."
apt-get update -y
apt-get upgrade -y

# ============================================
# 2. INSTALL DOCKER
# ============================================
echo "[2/6] Installing Docker..."
apt-get install -y ca-certificates curl gnupg lsb-release
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg

echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null

apt-get update -y
apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

# Enable Docker service
systemctl enable docker
systemctl start docker

# Add ubuntu user to docker group
usermod -aG docker ubuntu

echo "✅ Docker installed: $(docker --version)"

# ============================================
# 3. INSTALL XFCE DESKTOP
# ============================================
echo "[3/6] Installing XFCE Desktop Environment..."
apt-get install -y xfce4 xfce4-goodies

echo "✅ XFCE Desktop installed"

# ============================================
# 4. INSTALL TIGERVNC
# ============================================
echo "[4/6] Installing TigerVNC Server..."
apt-get install -y tigervnc-server tigervnc-common

# Create VNC startup script
mkdir -p /home/ubuntu/.vnc
cat > /home/ubuntu/.vnc/xstartup << 'EOF'
#!/bin/bash
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS
/usr/bin/startxfce4 &
EOF

chmod +x /home/ubuntu/.vnc/xstartup
chown -R ubuntu:ubuntu /home/ubuntu/.vnc

# Create systemd service for VNC
cat > /etc/systemd/system/vncserver@.service << 'EOF'
[Unit]
Description=TigerVNC server on display %i
After=syslog.target network-online.target remote-fs.target nss-lookup.target
Wants=network-online.target

[Service]
Type=forking
User=ubuntu
WorkingDirectory=/home/ubuntu
ExecStartPre=/bin/sh -c '/usr/bin/vncserver -kill %i > /dev/null 2>&1 || :'
ExecStart=/usr/bin/vncserver -depth 24 -geometry 1280x1024 %i
ExecStop=/bin/sh -c '/usr/bin/vncserver -kill %i > /dev/null 2>&1 || :'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

# Set VNC password
echo "${vnc_password}" | vncpasswd -f > /home/ubuntu/.vnc/passwd
chmod 600 /home/ubuntu/.vnc/passwd
chown ubuntu:ubuntu /home/ubuntu/.vnc/passwd

# Start VNC service
systemctl daemon-reload
systemctl enable vncserver@1
systemctl start vncserver@1

echo "✅ TigerVNC installed and running on port 5901"

# ============================================
# 5. INSTALL DEVOPS TOOLS
# ============================================
echo "[5/6] Installing DevOps tools..."

# Terraform
apt-get install -y wget unzip
TERRAFORM_VERSION="1.5.7"
cd /tmp
wget https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip
unzip terraform_${TERRAFORM_VERSION}_linux_amd64.zip
mv terraform /usr/local/bin/
rm terraform_${TERRAFORM_VERSION}_linux_amd64.zip

# AWS CLI
apt-get install -y awscli

# Git
apt-get install -y git

# Python & pip
apt-get install -y python3 python3-pip
pip3 install --upgrade pip
pip3 install boto3 ansible

# kubectl
curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
chmod +x kubectl
mv kubectl /usr/local/bin/

echo "✅ DevOps tools installed:"
terraform --version
aws --version
git --version
python3 --version
ansible --version

# ============================================
# 6. SYSTEM OPTIMIZATION & CLEANUP
# ============================================
echo "[6/6] Finalizing setup..."

# Enable CloudWatch agent (optional)
# wget https://s3.amazonaws.com/amazoncloudwatch-agent/ubuntu/amd64/latest/amazon-cloudwatch-agent.deb
# dpkg -i -E ./amazon-cloudwatch-agent.deb

# Clean up
apt-get autoremove -y
apt-get clean -y

echo ""
echo "=== Project Phoenix EC2 Initialization Complete ==="
echo ""
echo "✅ Access Methods:"
echo "   - SSH: ssh -i <key> ubuntu@$(curl -s http://169.254.169.254/latest/meta-data/public-ipv4)"
echo "   - VNC: $(curl -s http://169.254.169.254/latest/meta-data/public-ipv4):5901"
echo ""
echo "✅ Installed Services:"
echo "   - Docker: Running"
echo "   - XFCE Desktop: Ready"
echo "   - TigerVNC: Running on port 5901"
echo "   - AWS CLI, Terraform, kubectl, Git, Python, Ansible: Installed"
echo ""
echo "Setup Time: $(date)"
